# Required, set your Gemini API key.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-3.5-flash

# Optional, uncomment and set when running without the Slack CLI (npm start).
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Optional timed quiz nudges. Use Slack channel IDs, not channel names.
# SKILLBRIDGE_NUDGE_ENABLED=true
# SKILLBRIDGE_NUDGE_CHANNELS=C0123456789
# SKILLBRIDGE_NUDGE_USERS=U0123456789
# SKILLBRIDGE_NUDGE_INTERVAL_MINUTES=1440
# SKILLBRIDGE_NUDGE_TOPIC=Apex

# Optional channel IDs for channel-specific welcome messages.
# These are useful when channel names change or Slack API channel info is unavailable.
# SKILLBRIDGE_ANNOUNCEMENTS_CHANNEL_ID=C0123456789
# SKILLBRIDGE_GENERAL_CHANNEL_ID=C0123456790
# SKILLBRIDGE_MENTOR_ROOM_CHANNEL_ID=C0123456791
# SKILLBRIDGE_LEARNING_COMMUNITY_CHANNEL_ID=C0123456792

# Optional, uncomment and set for OAuth mode (node app-oauth.js).
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional, uncomment when serving the App Home logo from a custom public URL.
# OAuth mode serves this automatically from https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/assets/skillbridge-agent-logo.png.
# SKILLBRIDGE_LOGO_URL=https://YOUR_PUBLIC_HOST/skillbridge-agent-logo.png

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL
